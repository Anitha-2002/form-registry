# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (DB_NAME is an alias for POSTGRES_DB if POSTGRES_DB is unset)
POSTGRES_DB=sample_db
POSTGRES_USER=username
POSTGRES_PASSWORD=your-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: override default Asia/Kolkata
# TIME_ZONE=UTC

# CORS: True = allow any origin (dev only). Set False in production and list origins below.
CORS_ALLOW_ALL_ORIGINS=True
# Used only when CORS_ALLOW_ALL_ORIGINS=False (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000